<Ui xmlns="http://www.blizzard.com/wow/ui/" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.blizzard.com/wow/ui/ ..\FrameXML\UI.xsd">

  <!-- Hidden event frame -->
  <Frame name="FragCounterEventFrame">
    <Scripts>
      <OnLoad>FragCounter_OnLoad()</OnLoad>
      <OnEvent>FragCounter_OnEvent(event, arg1, arg2, arg3, arg4, arg5, arg6, arg7, arg8, arg9)</OnEvent>
      <OnUpdate>FragCounter_OnUpdate()</OnUpdate>
    </Scripts>
  </Frame>

  <!-- Main display frame -->
  <Frame name="FragCounterFrame" toplevel="true" movable="true" enableMouse="true" parent="UIParent" hidden="true">
    <Size>
      <AbsDimension x="250" y="64"/>
    </Size>
    <Anchors>
      <Anchor point="CENTER"/>
    </Anchors>
    <Backdrop bgFile="Interface\Tooltips\UI-Tooltip-Background" edgeFile="Interface\Tooltips\UI-Tooltip-Border" tile="true">
      <BackgroundInsets>
        <AbsInset left="4" right="4" top="4" bottom="4"/>
      </BackgroundInsets>
      <TileSize>
        <AbsValue val="16"/>
      </TileSize>
      <EdgeSize>
        <AbsValue val="16"/>
      </EdgeSize>
    </Backdrop>
    <Layers>
      <Layer level="ARTWORK">
        <FontString name="FragCounterTitle" inherits="GameFontNormalSmall" text="FragCounter">
          <Anchors>
            <Anchor point="TOP" relativeTo="FragCounterFrame" relativePoint="TOP">
              <Offset>
                <AbsDimension x="0" y="-8"/>
              </Offset>
            </Anchor>
          </Anchors>
          <Color r="1" g="0.82" b="0"/>
        </FontString>
        <FontString name="FragCounterSessionText" inherits="GameFontNormalSmall" justifyH="LEFT" text="Session: 0">
          <Anchors>
            <Anchor point="TOPLEFT" relativeTo="FragCounterFrame" relativePoint="TOPLEFT">
              <Offset>
                <AbsDimension x="10" y="-24"/>
              </Offset>
            </Anchor>
            <Anchor point="RIGHT" relativeTo="FragCounterFrame" relativePoint="CENTER">
              <Offset>
                <AbsDimension x="10" y="0"/>
              </Offset>
            </Anchor>
          </Anchors>
          <Color r="1" g="1" b="1"/>
        </FontString>
        <FontString name="FragCounterTodayText" inherits="GameFontNormalSmall" justifyH="LEFT" text="Today: 0">
          <Anchors>
            <Anchor point="TOPLEFT" relativeTo="FragCounterFrame" relativePoint="TOPLEFT">
              <Offset>
                <AbsDimension x="10" y="-38"/>
              </Offset>
            </Anchor>
            <Anchor point="RIGHT" relativeTo="FragCounterFrame" relativePoint="CENTER">
              <Offset>
                <AbsDimension x="10" y="0"/>
              </Offset>
            </Anchor>
          </Anchors>
          <Color r="1" g="1" b="1"/>
        </FontString>
        <FontString name="FragCounterRateText" inherits="GameFontNormalSmall" justifyH="RIGHT" text="">
          <Anchors>
            <Anchor point="LEFT" relativeTo="FragCounterFrame" relativePoint="CENTER">
              <Offset>
                <AbsDimension x="-10" y="0"/>
              </Offset>
            </Anchor>
            <Anchor point="TOPRIGHT" relativeTo="FragCounterFrame" relativePoint="TOPRIGHT">
              <Offset>
                <AbsDimension x="-10" y="-24"/>
              </Offset>
            </Anchor>
          </Anchors>
          <Color r="0.7" g="0.7" b="0.7"/>
        </FontString>
        <FontString name="FragCounterTotalText" inherits="GameFontNormalSmall" justifyH="RIGHT" text="">
          <Anchors>
            <Anchor point="LEFT" relativeTo="FragCounterFrame" relativePoint="CENTER">
              <Offset>
                <AbsDimension x="-10" y="0"/>
              </Offset>
            </Anchor>
            <Anchor point="TOPRIGHT" relativeTo="FragCounterFrame" relativePoint="TOPRIGHT">
              <Offset>
                <AbsDimension x="-10" y="-38"/>
              </Offset>
            </Anchor>
          </Anchors>
          <Color r="0.7" g="0.7" b="0.7"/>
        </FontString>
      </Layer>
    </Layers>
    <Scripts>
      <OnMouseDown>
        if arg1 == "LeftButton" and not FragCounterDB.locked then
          this:StartMoving()
        end
      </OnMouseDown>
      <OnMouseUp>
        this:StopMovingOrSizing()
        FragCounter_SaveFramePosition()
      </OnMouseUp>
    </Scripts>
  </Frame>

</Ui>
